<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LaptopStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LaptopStore.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
            <div class="container">

                <a class="navbar-brand fw-bold"
                   href="/">
                    💻 LaptopStore
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse"
                     id="navbarMain">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                               href="/">
                                Trang chủ
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="/Wishlist">
                                ❤️ Yêu thích
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="/Cart">
                                🛒 Giỏ hàng
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="/Admin/Dashboard">
                                📊 Admin
                            </a>
                        </li>

                    </ul>

                </div>
            </div>
        </nav>
           
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

<footer class="bg-dark text-white mt-5 p-4">

    <div class="container text-center">

        <h5>💻 LaptopStore</h5>

        <p>
            Đồ Án Xây dựng Web bán Laptop 
        </p>

        <p>
            Hotline: 0939.934.919
        </p>

        <p>
            © 2026 Team Binh Le - Đại Học TV - Lớp DK24TT8016_170124286
        </p>

    </div>

</footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
